# ============================================================================
# SLUG Sales OS — environment variables
# Copy this file to `.env.local` and fill in the values from your Supabase
# project (Project Settings -> API). NEVER commit `.env.local` or real keys.
# ============================================================================

# --- Client-safe (exposed to the browser) -----------------------------------
# These two are the ONLY Supabase values that may be public. The anon key is
# designed to be shipped to the browser and is protected by Row Level Security.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# --- Server-only (NEVER expose to the browser) ------------------------------
# The service role key bypasses Row Level Security. It is used ONLY in
# server-side code (route handlers / server actions). It must never be
# prefixed with NEXT_PUBLIC_, imported into a client component, or committed.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
